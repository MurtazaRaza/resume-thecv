# Copy to .env and fill in. .env is gitignored; this file is not.

# Which provider backs the LLM layer: ollama | anthropic | gemini
CVE_PROVIDER=ollama

# --- ollama (default, local, free) ------------------------------------------
CVE_OLLAMA_URL=http://localhost:11434
CVE_MODEL=qwen2.5:3b-instruct

# --- gemini ------------------------------------------------------------------
GEMINI_API_KEY=
CVE_GEMINI_MODEL=gemini-2.5-flash

# --- optional: per-task model overrides ---------------------------------------
# Only meaningful for the active provider above. Leave unset to use its default
# model everywhere. Task names: import, bullet_optimize, grammar, letters,
# jd_extract, tailor_suggest, summary, headline.
# CVE_TASK_MODEL_tailor_suggest=gemini-2.5-pro
